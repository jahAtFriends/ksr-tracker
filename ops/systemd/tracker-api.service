[Unit]
Description=KSR Tracker API
After=network.target

[Service]
Type=simple
User=tracker
Group=tracker
WorkingDirectory=/opt/ksr-tracker
EnvironmentFile=/opt/ksr-tracker/.env
ExecStart=/opt/ksr-tracker/.venv/bin/uvicorn server.app.main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
